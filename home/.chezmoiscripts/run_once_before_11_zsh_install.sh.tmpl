set -e # -e: exit on error

## Variables:
SCRIPT_NAME=$(basename "$0")
ZSH_PACKAGES=(
  zsh
  fonts-powerline
  zsh-syntax-highlighting
)

## Log (enhanced with colors and symbols):
header() {
  echo -e "\n\033[1;35m  $*\033[0m"
  echo -e "\033[1;35mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
}

info() {
  echo -e "\033[1;36m  в„№  $*\033[0m"
}

success() {
  echo -e "\033[1;32m  вњ“  $*\033[0m"
}

warning() {
  echo -e "\033[1;33m  вљ   WARNING: $*\033[0m"
}

error() {
  echo -e "\033[1;31m  вњ—  ERROR: $*\033[0m" >&2
}

step() {
  echo -e "\n\033[1;34m  в†’  $*\033[0m"
}

prompt() {
  echo -e "\033[1;33m  ?  $*\033[0m"
}

## Helper function: ask user confirmation
ask_user() {
  local question="$1"
  local response
  
  prompt "$question (y/N): "
  read -r response
  
  case "$response" in
    [yY][eE][sS]|[yY])
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

## Main
header "chezmoi script: before 11 - zsh, Oh-my-zsh, Powerlevel10k theme installation"

# Ask user for installation
if ! ask_user "Do you want to proceed ?"; then
  echo ""
  info "Installation cancelled by user"
  echo ""
  exit 0
fi

# Zsh packages install
# step "Checking and installing required zsh packages..."
