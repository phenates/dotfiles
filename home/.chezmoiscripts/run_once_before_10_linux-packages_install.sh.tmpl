info() {
  echo -e "\033[1;36m  ‚Ñπ  $*\033[0m"
}

success() {
  echo -e "\033[1;32m  ‚úì  $*\033[0m"
}

warning() {
  echo -e "\033[1;33m  ‚ö†  WARNING: $*\033[0m"
}

error() {
  echo -e "\033[1;31m  ‚úó  ERROR: $*\033[0m" >&2
}

step() {
  echo -e "\n\033[1;34m  ‚Üí  $*\033[0m"
}

## Main
header "SCRIPT: Linux packages installation"

# Install packages
step "Checking and installing required packages..."
for package in "${LINUX_PACKAGES[@]}"; do
  if ! command -v "$package" &>/dev/null; then
    step "Installing $package..."
    # Installation avec gestion sudo/root
    if sudo apt install -qq -y "$package" 2>/dev/null; then
      success "$package installed"
    else
      error "Failed to install $package"
      exit 1
    fi
  else
    info "$package already installed"
  fi
done

echo ""
success "Linux packages installation completed! üéâ"
echo ""

