{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

#==============================================================================
#description  :chezmoi bash script, running after `chezmoi apply`
#              Configure zsh as default shell.
#version      :0.3
#date         :2025-10-17
#==============================================================================

# Source utility functions
source "{{ .chezmoi.sourceDir -}}/.utils/utils.sh"

set -e # -e: exit on error

## Main
header "Script - sudo Passwordless configuration"

REAL_USER="{{ .chezmoi.username }}"
SUDOERS_FILE="/etc/sudoers.d/${REAL_USER}"

step "zsh stack"
info "zsh         — installed via packages script"
info "oh-my-zsh   — managed as chezmoi external"
info "Nerd fonts  — managed as chezmoi external"

# Change default shell to zsh
if grep -qF "NOPASSWD" "${SUDOERS_FILE}" 2>/dev/null; then
    info "Passwordless sudo already configured for ${REAL_USER} (${SUDOERS_FILE})"
else
    # info "Granting passwordless sudo to ${REAL_USER}"
    echo "${REAL_USER} ALL=(ALL) NOPASSWD: ALL" | sudo tee "${SUDOERS_FILE}" > /dev/null
    sudo chmod 0440 "${SUDOERS_FILE}"
    success "Created ${SUDOERS_FILE}"
fi

{{ end -}}