{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

#==============================================================================
#description  :chezmoi bash script, running before `chezmoi apply`.
#              Ensures sudo is installed, user is in the sudo group, and
#              passwordless sudo is configured. Must run first — all subsequent
#              scripts rely on passwordless sudo.
#version      :0.2
#date         :2026-05-15
#==============================================================================

# Source utility functions
source "{{ .chezmoi.sourceDir -}}/.utils/utils.sh"

set -e

# Use sudo only when not already running as root
{{- $sudo := "sudo " -}}
{{- if eq .chezmoi.username "root" -}}
{{-   $sudo = "" -}}
{{- end }}

## Main
header "Script - sudo configuration"

REAL_USER="{{ .chezmoi.username }}"
SUDOERS_FILE="/etc/sudoers.d/${REAL_USER}"

# ── Step 1: ensure sudo is installed ─────────────────────────────────────────
step "sudo package"
if command_exists sudo; then
    info "sudo — already installed"
else
    info "sudo — not found, installing..."
    {{ $sudo }}apt-get install -y sudo
    success "sudo installed"
fi

# ── Step 2: ensure user is in the sudo group ─────────────────────────────────
step "sudo group membership for ${REAL_USER}"
if id -nG "${REAL_USER}" | grep -qw "sudo"; then
    info "${REAL_USER} — already in sudo group"
else
    {{ $sudo }}usermod -aG sudo "${REAL_USER}"
    success "${REAL_USER} added to sudo group"
fi

# ── Step 3: passwordless sudo via sudoers.d ───────────────────────────────────
step "Passwordless sudo for ${REAL_USER}"
if {{ $sudo }}grep -qF "NOPASSWD" "${SUDOERS_FILE}" 2>/dev/null; then
    info "Already configured: ${SUDOERS_FILE}"
else
    echo "${REAL_USER} ALL=(ALL) NOPASSWD: ALL" | {{ $sudo }}tee "${SUDOERS_FILE}" > /dev/null
    {{ $sudo }}chmod 0440 "${SUDOERS_FILE}"
    if {{ $sudo }}visudo -c > /dev/null 2>&1; then
        success "Created ${SUDOERS_FILE}"
    else
        error "sudoers validation failed — reverting"
        {{ $sudo }}rm -f "${SUDOERS_FILE}"
        exit 1
    fi
fi

echo ""
success "🎉 sudo configuration complete! 🎉"
echo ""

{{ end -}}
