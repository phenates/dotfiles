{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

#==============================================================================
#description  :chezmoi bash script, running after `chezmoi apply`
#              Configure zsh as default shell.
#version      :0.3
#date         :2025-10-17
#==============================================================================

# Source utility functions
source "{{ .chezmoi.sourceDir -}}/.utils/utils.sh"

set -e # -e: exit on error

{{- $sudo := "sudo " -}}
{{- if eq .chezmoi.username "root" -}}
{{-   $sudo = "" -}}
{{- end }}

## Main
header "Script - zsh shell"

REAL_USER="{{ .chezmoi.username }}"

step "zsh stack"
info "zsh         — installed via packages script"
info "oh-my-zsh   — managed as chezmoi external"
info "Nerd fonts  — managed as chezmoi external"

step "Refreshing font cache..."
if fc-cache -fv > /dev/null 2>&1; then
    success "Font cache refreshed"
else
    warning "fc-cache failed — fonts may not be available until next login"
fi

# Change default shell to zsh
# Uses usermod (requires sudo) instead of chsh to avoid PAM password prompt
step "Change default shell to zsh..."
ZSH_PATH=$(which zsh)
CURRENT_SHELL=$(getent passwd "${REAL_USER}" | cut -d: -f7)
if [[ "${CURRENT_SHELL}" == "${ZSH_PATH}" ]]; then
    info "zsh is already the default shell"
else
    if {{ $sudo }}usermod -s "${ZSH_PATH}" "${REAL_USER}"; then
        success "Default shell changed to zsh"
        info "Logout and login, or run 'exec zsh' for the change to take effect."
    else
        error "Failed to change default shell to zsh"
    fi
fi

{{ end -}}
