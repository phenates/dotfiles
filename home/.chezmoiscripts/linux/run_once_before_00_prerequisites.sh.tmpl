{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

#==============================================================================
#description  :chezmoi bash script, running once before `chezmoi apply`.
#              Checks that required system tools are available before any
#              other script runs. Fails fast with clear instructions if not.
#version      :0.1
#date         :2026-05-13
#==============================================================================

# Source utility functions
source "{{ .chezmoi.sourceDir -}}/.utils/utils.sh"

set -e

## Main
header "Script - Prerequisites check"

step "Required tools"

REQUIRED_TOOLS=("sudo" "curl" "git" "apt-get")
MISSING=()

for tool in "${REQUIRED_TOOLS[@]}"; do
    if command -v "$tool" &>/dev/null; then
        info "${tool} — found"
    else
        error "${tool} — NOT FOUND"
        MISSING+=("$tool")
    fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
    error "Missing prerequisites: ${MISSING[*]}"
    info "Install them manually then re-run: chezmoi apply"
    exit 1
fi

success "All prerequisites satisfied"

{{ end -}}
