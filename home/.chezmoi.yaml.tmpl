{{- /* File use to customize the chezmoi config file when doing a `chezmoi init`. */ -}}
{{- /* Use template to populate or trigger prompts to populate values. */ -}}

{{- /* Default values */ -}}
{{- $private := false -}}{{/* true if this machine should have personal secrets */}}

{{- /* Prompts */ -}}
{{- writeToStdout "\n  chezmoi configuration:  \n" -}}
{{- $private := promptBool "\n  ?  This is a private installation (should have personal secrets) ? (y/n)" false -}}
{{- writeToStdout "  This is a private installation (should have personal secrets) ? -> Responce: $private  \n" -}}

{{- $changeShell := promptBool "\n  ?  Change default shell to zsh ? (y/n)" false -}}
{{- writeToStdout "  Change default shell to zsh ? -> Responce: $changeShell  \n" -}}

{{- /* OS infos */ -}}
{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end -}}

data:
  name: "phenates"
  email: "phen4tes@gmail.com"
  osid: {{ $osID | quote }}
  isWSL: {{ $isWSL }}
  signingKey: ""
  chezmoi_package: "https://github.com/twpayne/chezmoi/releases/download/v{{ .chezmoi.version.version }}/chezmoi_{{ .chezmoi.version.version }}_linux_amd64.deb"
  private: {{ $private }}
  changeShell: {{ $changeShell }}

edit:
  command: "nano"

git:
  autoCommit: true
  autoPush: true
