{{/* Generates ~/.config/chezmoi/chezmoi.yaml on `chezmoi init`. */}}
{{/* Re-evaluated on every `chezmoi init` call (not on `chezmoi apply`). */}}


{{- /* ── 1. State: load existing configuration ────────────────────────────── */ -}}
{{- $previousConfig := dict -}}
{{- $configPath := joinPath .chezmoi.homeDir ".config" "chezmoi" "chezmoi.yaml" -}}
{{- if stat $configPath -}}
{{-   $previousConfig = include $configPath | fromYaml -}}
{{- end -}}


{{- /* ── 2. Mode: interactive only on re-init from a TTY ────────────────────── */ -}}
{{- /* First init (no existing config) → silent, uses defaults.               */ -}}
{{- /* Re-init from a TTY             → interactive prompts to change settings.*/ -}}
{{- /* Re-init without TTY (Ansible)  → silent, keeps previous values.        */ -}}
{{- $interactive := and stdinIsATTY (hasKey $previousConfig "data") -}}


{{- /* ── 3. Previous values (or hardcoded defaults on first run) ─────────────── */ -}}
{{- $environmentTags := list -}}
{{- $previousEnvTags := list "core" -}}
{{- if hasKey $previousConfig "data" -}}
{{-   if hasKey $previousConfig.data "environmentTags" -}}
{{-     $previousEnvTags = $previousConfig.data.environmentTags -}}
{{-   end -}}
{{- end -}}


{{- /* ── 4. Prompts ─────────────────────────────────────────────────────────── */ -}}
{{- writeToStdout (printf "\n⮞  chezmoi -> host configuration\n") -}}
{{- writeToStdout (printf "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n") -}}

{{- if $interactive -}}
{{-   $tag_choices := list "core" -}} {{/* extend here: "dev" "ai" "sysAdmin" "devOps" */}}
{{-   $environmentTags = promptMultichoice "  ?  Select environment tags for this machine" $tag_choices $previousEnvTags -}}
{{-   writeToStdout (printf "    ➜ '%s' \n\n" $environmentTags) -}}
{{- else -}}
{{-   $environmentTags = $previousEnvTags -}}
{{-   writeToStdout (printf "    ➜ environmentTags: %v (auto)\n\n" $environmentTags) -}}
{{- end -}}


{{- /* ── 5. OS detection ─────────────────────────────────────────────────────── */ -}}
{{- $OS_ID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $OS_ID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{- /* WSL: used in templates to skip behaviors unavailable under WSL (e.g. chsh) */ -}}
{{- $is_WSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{-     $is_WSL = true -}}
{{-   end -}}
{{- end -}}


{{- /* ── 6. YAML output ──────────────────────────────────────────────────────── */ -}}
data:
  name: "phenates"
  email: "phen4tes@gmail.com"
  OS_id: {{ $OS_ID | quote }}
  is_WSL: {{ $is_WSL }}
  environmentTags: {{ $environmentTags | toToml }}


{{/* Editor used by `chezmoi edit` */}}
{{ if eq .chezmoi.os "linux" -}}
edit:
  command: "nano"
{{ else if eq .chezmoi.os "windows" -}}
{{   if lookPath "code" -}}
edit:
  command: "code"
  args: ["--wait"]
{{   else -}}
edit:
  command: "notepad"
{{   end -}}
{{ end }}


{{/* Auto-commit and push source directory changes after each `chezmoi apply` */}}
git:
  autoCommit: true
  autoPush: true
