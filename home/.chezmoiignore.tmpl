{{/* .chezmoiignore.tmpl — controls which files chezmoi applies to the target directory.
     Evaluated as a Go template on every `chezmoi apply`.
     Paths are relative to ~ (the home directory).

     Syntax:
       pattern        Ignore this path (never apply it).
       !pattern       Un-ignore — force-include even if a parent rule excluded it.
       glob syntax    Standard gitignore-style globs (* ** ? [range]).
       {{ if ... }}   Go template conditions — dynamic ignore rules based on OS, tags, etc.
*/}}

# ── Repo files — never applied to ~ ──────────────────────────────────────────
# These files live in the dotfiles source repo but have no place in the home dir.
install.sh
README.md


# ── oh-my-zsh ─────────────────────────────────────────────────────────────────
# oh-my-zsh is managed as an external source (.chezmoiexternal.yaml.tmpl).
# chezmoi must not touch the bulk of the directory, but the custom plugins
# and themes sub-tree is explicitly un-ignored so chezmoi can manage it.
# Compiled zsh files (*.zwc) generated at runtime are excluded to avoid
# chezmoi detecting spurious diffs on every apply.
!.oh-my-zsh/plugins
!.oh-my-zsh/plugins/**
.oh-my-zsh/cache/**
.oh-my-zsh/templates/**
.oh-my-zsh/custom/themes/powerlevel10k/**/*.zwc


# ── OS-specific files ─────────────────────────────────────────────────────────
# Scripts and dotfiles that only make sense on their target OS are excluded
# on all other platforms to avoid applying irrelevant configuration.

{{ if ne .chezmoi.os "linux" }}
# Not on Linux — ignore all Linux-specific scripts and shell config
.chezmoiscripts/linux/**
.bashrc
.nanorc
.p10k.zsh
.sh_aliases
.sh_functions
.zshrc
.oh-my-zsh/**
.config/bat
{{ end }}

{{ if ne .chezmoi.os "windows" }}
# Not on Windows — ignore all Windows-specific scripts and app config
.chezmoiscripts/windows
Documents
.config/ohmyposh
AppData/**
{{ end }}


# ── WSL — SSH directory ───────────────────────────────────────────────────────
# On WSL, ~/.ssh is a symlink pointing to the Windows .ssh directory
# (created by run_onchange_after_61_wsl-simlinks.sh).
# chezmoi must not touch .ssh at all here: the symlink would be replaced by a
# directory. On native Linux, chezmoi manages .ssh normally.
{{ if .is_WSL }}
.ssh
.ssh/**
{{ end }}
