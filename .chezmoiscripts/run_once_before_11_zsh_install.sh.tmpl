#==============================================================================
#title            :run_once_before_11_zsh_install.sh.tmpl
#description      :Action script for chezmoi.io, install zsh and oh-my-zsh.
#author		        :phenates
#date             :2025-10-14
#version          :0.2 
#usage		        :used by chezmoi apply sequence
#==============================================================================

set -e # -e: exit on error

## Variables:
SCRIPT_NAME=$(basename "$0")
ZSH_PACKAGES=(
  zsh
  fonts-powerline
  zsh-syntax-highlighting
)

## Log (enhanced with colors and symbols):
header() {
  echo -e "\n\033[1;35m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
  echo -e "\033[1;35m  $*\033[0m"
  echo -e "\033[1;35m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
}

info() {
  echo -e "\033[1;36m  ℹ  $*\033[0m"
}

success() {
  echo -e "\033[1;32m  ✓  $*\033[0m"
}

warning() {
  echo -e "\033[1;33m  ⚠  WARNING: $*\033[0m"
}

error() {
  echo -e "\033[1;31m  ✗  ERROR: $*\033[0m" >&2
}

step() {
  echo -e "\033[1;34m  →  $*\033[0m"
}

prompt() {
  echo -e "\033[1;33m  ?  $*\033[0m"
}

## Helper function: ask user confirmation
ask_user() {
  local question="$1"
  local response
  
  prompt "$question (y/N): "
  read -r response
  
  case "$response" in
    [yY][eE][sS]|[yY])
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

## Main
header "SCRIPT: zsh shell, Oh-my-zsh (plungins, theme) installation"

# Ask user for installation
if ! ask_user "Do you want to install them now?"; then
  echo ""
  info "Installation cancelled by user"
  echo ""
  exit 0
fi

# Zsh packages install
step "Checking and installing required zsh packages..."
for package in "${ZSH_PACKAGES[@]}"; do
  if ! command -v "$package" &>/dev/null; then
    step "Installing $package..."
    # Installation avec gestion sudo/root
    if sudo apt install -qq -y "$package" 2>/dev/null; then
      success "$package installed"
      echo ""
    else
      error "Failed to install $package"
      exit 1
    fi
  else
    info "$package already installed"
    echo ""
  fi
done

# Oh-my-zsh install
step "Checking and installing required zsh packages..."
if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
  sh -c "$(wget -O- https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended >/dev/null
  success "oh-my-zsh installed"
else
  info "oh-my-zsh already installed"
fi

# Change default shell to zsh
step "Change default shell to zsh..."
if command -v chsh -s $(which zsh) &>/dev/null; then
  success "Default shell changed to zsh"
  info "You may need to log out and log back in for the change to take effect."
else
  error "Failed to change default shell to zsh"
fi

echo ""
success "zsh installation completed! 🎉"
echo ""

{{ end -}}