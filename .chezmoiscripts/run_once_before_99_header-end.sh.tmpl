#!/bin/bash
{{ if (and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "debian" "ubuntu")) -}}
#^^^ chezmoi script running template condition, must be the first line after the shebang ^^^

#==============================================================================
#title            :run_once_before_99_header-end.sh.tmpl
#description      :Action script for chezmoi.io, "Script Execution Finished" header.
#author		        :phenates
#date             :2025-10-14
#version          :0.1
#usage		        :used by chezmoi apply sequence
#==============================================================================

set -e # -e: exit on error

## Variables:
PACKAGE_URL={{ .chezmoi_package }}
TEMP_DEB="/tmp/chezmoi_package.deb"

## Cleanup on exit
trap 'rm -f "$TEMP_DEB"' EXIT

## Log (enhanced with colors and symbols):
header() {
  echo -e "\n\033[1;35m━*************************************************\033[0m"
  echo -e "\033[1;35m  $*\033[0m"
  echo -e "\033[1;35m*************************************************\033[0m"
}

## Main
header "CHEZMOI: Script Execution Finished"

{{ end -}}