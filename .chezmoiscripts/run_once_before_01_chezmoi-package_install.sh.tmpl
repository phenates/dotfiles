#!/bin/bash

{{ if (and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "debian" "ubuntu")) -}}
#^^^ chezmoi script running template condition, must be the first line after the shebang ^^^

#==============================================================================
#title            :mkscript.sh
#description      :Action script for chezmoi.io, install chezmoi package (to benefit of autocompleting) and
#                  remove the binary file downloaded during the official installation command (sh -c "$(curl -fsLS get.chezmoi.io)").
#author		        :phenates
#date             :2025-10-14
#version          :0.2    
#usage		        :used by chezmoi apply sequence
#==============================================================================

set -e # -e: exit on error

## Variables:
PACKAGE_URL={{ .chezmoi_package }}
TEMP_DEB="/tmp/chezmoi_package.deb"

## Cleanup on exit
trap 'rm -f "$TEMP_DEB"' EXIT

## Log (enhanced with colors and symbols):
header() {
  echo -e "\n\033[1;35mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
  echo -e "\033[1;35m  $*\033[0m"
  echo -e "\033[1;35mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
}

info() {
  echo -e "\033[1;36m  в„№  $*\033[0m"
}

success() {
  echo -e "\033[1;32m  вњ“  $*\033[0m"
}

warning() {
  echo -e "\033[1;33m  вљ   WARNING: $*\033[0m"
}

error() {
  echo -e "\033[1;31m  вњ—  ERROR: $*\033[0m" >&2
}

step() {
  echo -e "\033[1;34m  в†’  $*\033[0m"
}

## Main
header "CHEZMOI: Replace Binary with Package"

# Validation
step "Validating configuration..."
if [[ -z "$PACKAGE_URL" ]]; then
  error "PACKAGE_URL is not defined"
  exit 1
fi
success "Configuration validated"

# Install chezmoi package
step "Downloading chezmoi .deb from: $PACKAGE_URL"
if ! wget -q -O "$TEMP_DEB" "$PACKAGE_URL" 2>/dev/null; then
  error "Failed to download package"
  exit 1
fi
success "Package downloaded successfully"

step "Installing chezmoi apt package..."
if ! sudo apt install -qq -y "$TEMP_DEB" 2>/dev/null; then
  error "Failed to install package"
  exit 1
fi
success "Chezmoi apt package installed"

# Remove chezmoi binary
step "Cleaning up binary installation..."
if [[ -f "$HOME/bin/chezmoi" ]]; then
  rm -f "$HOME/bin/chezmoi"
  success "Chezmoi binary file removed"
else
  info "No binary file found in ~/bin (skipped)"
fi

# Remove install.sh script
if [[ -f "$HOME/install.sh" ]]; then
  rm -f "$HOME/install.sh"
  success "install.sh file removed"
else
  info "No install.sh file found (skipped)"
fi

echo ""
success "Chezmoi package installation completed! рџЋ‰"
echo ""

{{ end -}}